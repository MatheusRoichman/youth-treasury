{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!node_modules", "!.next", "!dist", "!build"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noUnknownAtRules": "off"
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ["react"],
              ":BLANK_LINE:",
              [":EXTERNAL:"],
              ":BLANK_LINE:",
              ["@/lib/"],
              ":BLANK_LINE:",
              ["@/components/ui/"],
              ":BLANK_LINE:",
              ["@/components/"],
              ":BLANK_LINE:",
              [":RELATIVE:"]
            ]
          }
        }
      }
    }
  }
}
